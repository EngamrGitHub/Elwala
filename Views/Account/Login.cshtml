@model Elwala.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - El-Lwaa Law Firm</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        .split-left {
            width: 50%;
            background-color: #1a2b3c;
            background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 30px 30px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 40px;
            text-align: center;
            position: relative;
        }

        /* Subtle gradient overlay */
        .split-left::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(135deg, rgba(16,26,36,0) 0%, rgba(16,26,36,0.8) 100%);
            pointer-events: none;
        }

        .left-content {
            z-index: 1;
            max-width: 450px;
        }

        .split-right {
            width: 50%;
            background-color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        .login-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        }

        .login-title {
            color: #000;
            font-weight: 700;
            font-size: 1.75rem;
            margin-bottom: 0.25rem;
        }

        .login-subtitle {
            color: #6b7280;
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #111827;
        }

        .form-control {
            background-color: #f3f4f6;
            border: 1px solid transparent;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            color: #111827;
        }

        .form-control:focus {
            background-color: #ffffff;
            border-color: #d4af37;
            box-shadow: 0 0 0 0.25rem rgba(212, 175, 55, 0.25);
        }

        .btn-submit {
            background-color: #1a2b3c;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            padding: 0.75rem;
            font-weight: 600;
            width: 100%;
            margin-top: 1rem;
            transition: background-color 0.3s;
        }

        .btn-submit:hover {
            background-color: #0d1b2a;
            color: #ffffff;
        }

        .error-alert {
            background-color: #fee2e2;
            color: #dc2626;
            padding: 0.75rem;
            border-radius: 8px;
            text-align: center;
            font-size: 0.9rem;
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .features-list {
            list-style: none;
            padding: 0;
            margin-top: 2rem;
            text-align: center;
        }

        .features-list li {
            margin-bottom: 1rem;
            color: #d1d5db;
            font-size: 0.95rem;
        }

        .features-list li::before {
            content: '●';
            color: #10b981;
            margin-right: 8px;
            font-size: 0.8rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            body {
                flex-direction: column;
                overflow-y: auto;
            }
            .split-left, .split-right {
                width: 100%;
                min-height: 50vh;
            }
            .split-left {
                padding: 40px 20px;
            }
            .split-right {
                padding: 40px 20px;
            }
        }
    </style>
</head>
<body>

    <div class="split-left">
        <div class="left-content">
            <img src="/images/logo.png" alt="El-Lwaa Law Firm" style="max-height: 90px; max-width: 90%; margin-bottom: 2rem; object-fit: contain;" />
            
            <p style="color: #e5e7eb; font-size: 1.1rem; line-height: 1.6;">
                Manage your legal entities and company<br />
                formations with Ellwaa Group
            </p>

            <ul class="features-list">
                <li>Legal Entity Management</li>
                <li>Company Creation & Compliance</li>
            </ul>
        </div>
    </div>

    <div class="split-right">
        <div class="login-card">
            <h1 class="login-title">Sign in to continue</h1>
            <p class="login-subtitle">Welcome Back</p>

            <form asp-action="Login" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-alert">
                        Login failed. Please try again.
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Username" class="form-label">Email or Username</label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>
                
                <button type="submit" class="btn-submit">Sign In</button>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
