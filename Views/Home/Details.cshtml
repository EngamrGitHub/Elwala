@model Elwala.Models.AffiliateRequest

@{
    ViewData["Title"] = "Affiliate Details";
    var uniqueUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/go/{Model.Slug}";
    var approvedPayments = Model.Payments?.Count(p => p.Status == Elwala.Models.AffiliateStatus.Approved) ?? 0;
    var successCount = Math.Max(Model.Count, approvedPayments);
}

<style>
    body {
        background: #f8f9fa !important;
        color: #111827 !important;
    }
    .glass-card {
        background: #ffffff !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
        border: 1px solid #e5e7eb !important;
        border-radius: 12px;
        padding: 2rem;
    }
    .stat-box {
        border-radius: 10px;
        padding: 1.25rem;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                    <div>
                        <h2 class="fw-bold m-0" style="color: #1a2b3c;">
                            <i class="bi bi-person-badge text-warning me-2"></i>@Model.FullName
                        </h2>
                        <span class="badge bg-light text-dark border mt-1">@Model.Slug</span>
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary mt-1 me-1">@Model.Type</span>
                    </div>
                    <div>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2" style="font-weight: 600;">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Dashboard" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Dashboard
                        </a>
                    </div>
                </div>

                <!-- KPI Quick Summary -->
                <div class="row mb-4">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="stat-box border-start border-4 border-success">
                            <div class="text-muted small text-uppercase fw-bold">Success Count (العدد الناجح)</div>
                            <div class="fs-2 fw-bold text-success mt-1">@successCount</div>
                        </div>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <div class="stat-box border-start border-4 border-info">
                            <div class="text-muted small text-uppercase fw-bold">Visits Count (عدد الزيارات)</div>
                            <div class="fs-2 fw-bold text-info mt-1">@Model.VisitsCount</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-box border-start border-4 border-primary">
                            <div class="text-muted small text-uppercase fw-bold">Total Recorded Transactions</div>
                            <div class="fs-2 fw-bold text-primary mt-1">@(Model.Payments?.Count ?? 0)</div>
                        </div>
                    </div>
                </div>

                <!-- Info Cards -->
                <div class="row mb-4">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <div class="card h-100 border">
                            <div class="card-header bg-light fw-bold text-dark">
                                <i class="bi bi-info-circle me-1"></i> Basic Information
                            </div>
                            <div class="card-body">
                                <p class="mb-2"><strong>Phone Number:</strong> @Model.PhoneNumber</p>
                                <p class="mb-2"><strong>Default Language:</strong> <span class="badge bg-secondary">@Model.LanguageCode</span></p>
                                <p class="mb-0"><strong>Registration Date:</strong> @Model.CreatedAt.ToString("yyyy-MMM-dd HH:mm") UTC</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100 border">
                            <div class="card-header bg-light fw-bold text-dark">
                                <i class="bi bi-link-45deg me-1"></i> Unique Generated Link
                            </div>
                            <div class="card-body d-flex flex-column justify-content-center">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="uniqueLinkInput" value="@uniqueUrl" readonly />
                                    <button class="btn btn-outline-primary" onclick="copyLink()">
                                        <i class="bi bi-clipboard"></i> Copy
                                    </button>
                                </div>
                                <small class="text-muted mt-2 d-block">Share this referral link with clients.</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Platform URLs -->
                <div class="card mb-4 border">
                    <div class="card-header bg-light fw-bold text-dark">
                        <i class="bi bi-globe me-1"></i> Platform URLs
                    </div>
                    <div class="card-body">
                        @if (Model.PlatformUrls != null && Model.PlatformUrls.Any())
                        {
                            <ul class="list-group">
                                @foreach (var p in Model.PlatformUrls)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">@p.Key</span>
                                        <a href="@p.Value" target="_blank" class="text-decoration-none text-primary">
                                            @p.Value <i class="bi bi-box-arrow-up-right ms-1"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <span class="text-muted">No platform URLs recorded.</span>
                        }
                    </div>
                </div>

                <!-- Payments History -->
                <div class="card border">
                    <div class="card-header bg-light fw-bold text-dark d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-clock-history me-1"></i> Payment & Conversion History
                        </div>
                        <span class="badge bg-success">Approved Only</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var approvedList = Model.Payments?.Where(p => p.Status == Elwala.Models.AffiliateStatus.Approved).OrderByDescending(p => p.CreatedAt).ToList() ?? new List<Elwala.Models.AffiliatePayment>();
                                    }
                                    @if (approvedList.Any())
                                    {
                                        foreach (var pay in approvedList)
                                        {
                                            <tr>
                                                <td>@pay.Id</td>
                                                <td>@pay.CreatedAt.ToString("yyyy-MMM-dd HH:mm")</td>
                                                <td>
                                                    <span class="badge bg-success">@pay.Status</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else if (Model.Count > 0)
                                    {
                                        @for (int i = 1; i <= Model.Count; i++)
                                        {
                                            <tr>
                                                <td>#@i</td>
                                                <td>@Model.CreatedAt.ToString("yyyy-MMM-dd HH:mm")</td>
                                                <td>
                                                    <span class="badge bg-success">Approved</span>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center py-3 text-muted">No approved payment records.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyLink() {
            var copyText = document.getElementById("uniqueLinkInput");
            copyText.select();
            copyText.setSelectionRange(0, 99999);
            navigator.clipboard.writeText(copyText.value);
            alert("Link copied to clipboard: " + copyText.value);
        }
    </script>
}
