@model AffiliateRequest

@{
    ViewData["Title"] = "Become an Affiliate";
}

<style>
    /* Override dark theme for this page */
    body {
        background: #f8f9fa !important; /* Soft white/light gray background */
        color: #111827 !important;
    }
    .glass-card {
        background: #ffffff !important;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08) !important;
        border: 1px solid #e5e7eb !important;
    }
    .glass-card p.text-secondary {
        color: #4b5563 !important;
    }
    .form-control, .form-select, .input-group-text {
        background-color: #ffffff !important;
        color: #111827 !important;
        border: 1px solid #d1d5db !important;
    }
    .form-label {
        color: #374151 !important;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="glass-card mt-3 p-4">
                <div class="text-center mb-5">
                    <img src="/images/logo.png" alt="El-Lwaa Logo" class="mb-3" style="max-height: 70px; max-width: 100%; object-fit: contain;" />
                    <h2 class="fw-bold" style="background: linear-gradient(90deg, #d4af37, #f1e5ac); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Admin: Generate Affiliate Link</h2>
                    <p class="text-secondary">Fill in the partner's details to generate a unique tracking link</p>
                </div>

                <div class="card-body">

                    <form asp-action="Affiliate" method="post">

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label asp-for="FullName" class="form-label">Partner Full Name</label>
                                <input asp-for="FullName" class="form-control" placeholder="e.g. Ahmed Ali" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label">Contact Number</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. +20 100 123 4567" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label asp-for="Slug" class="form-label">URL Slug (e.g., tech_guru)</label>
                                <div class="input-group">
                                    <span class="input-group-text border-secondary" style="background-color: rgba(15,23,42,0.4); color: #94a3b8;">.../go/</span>
                                    <input asp-for="Slug" class="form-control" placeholder="tech_guru" />
                                </div>
                                <span asp-validation-for="Slug" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label">Partner Type</label>
                                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<Elwala.Models.PartnerType>()">
                                    <option value="">Select Type...</option>
                                </select>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="LanguageCode" class="form-label">Default Link Language</label>
                                <select asp-for="LanguageCode" class="form-select">
                                    <option value="ar">العربية (Arabic)</option>
                                    <option value="en">English</option>
                                    <option value="zh">中文 (Chinese)</option>
                                    <option value="ur">اردو (Urdu)</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label d-flex justify-content-between align-items-center">
                                <span>Platform URLs</span>
                                <button type="button" class="btn btn-sm rounded-pill px-3" style="border: 1px solid #d4af37; color: #d4af37; background: transparent;" onmouseover="this.style.background='#d4af37'; this.style.color='#1a2b3c';" onmouseout="this.style.background='transparent'; this.style.color='#d4af37';" onclick="addPlatformField()">
                                    <i class="bi bi-plus-lg"></i> Add URL
                                </button>
                            </label>
                            <div id="platformsContainer">
                                <!-- Dynamic fields will be added here -->
                                <div class="row mb-2 platform-row">
                                    <div class="col-4">
                                        <input type="text" name="PlatformUrls[0].Key" class="form-control" placeholder="Platform (e.g., YouTube)" />
                                    </div>
                                    <div class="col-7">
                                        <input type="url" name="PlatformUrls[0].Value" class="form-control" placeholder="URL (e.g., https://youtube.com/c/tech)" />
                                    </div>
                                    <div class="col-1 d-flex align-items-center justify-content-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger py-2 px-3" title="Remove URL" onclick="this.closest('.platform-row').remove()">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-primary btn-lg shadow-lg">
                                <i class="bi bi-link-45deg me-2"></i> Generate Secure Link
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        let platformIndex = 1;
        function addPlatformField() {
            const container = document.getElementById('platformsContainer');
            const row = document.createElement('div');
            row.className = 'row mb-2 platform-row';
            row.innerHTML = `
                <div class="col-4">
                    <input type="text" name="PlatformUrls[${platformIndex}].Key" class="form-control" placeholder="Platform (e.g., Instagram)" />
                </div>
                <div class="col-7">
                    <input type="url" name="PlatformUrls[${platformIndex}].Value" class="form-control" placeholder="URL" />
                </div>
                <div class="col-1 d-flex align-items-center justify-content-center">
                    <button type="button" class="btn btn-sm btn-outline-danger py-2 px-3" title="Remove URL" onclick="this.closest('.platform-row').remove()">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            `;
            container.appendChild(row);
            platformIndex++;
        }
    </script>
}